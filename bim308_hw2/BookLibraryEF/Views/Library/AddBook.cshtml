@model BookLibraryEF.Models.Book

@{
    ViewData["Title"] = "Add Book";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0" style="border-radius: 16px;">
                <div class="card-header text-white text-center" style="background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius: 16px 16px 0 0;">
                    <h3 class="mb-0"><i class="fas fa-plus-circle"></i> Add New Book</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="AddBook" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold">
                                <i class="fas fa-heading text-primary"></i> Title
                            </label>
                            <input asp-for="Title" class="form-control" placeholder="Enter book title" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AuthorID" class="form-label fw-bold">
                                <i class="fas fa-user-edit text-primary"></i> Author
                            </label>
                            <select asp-for="AuthorID" asp-items="@ViewBag.Authors" class="form-select">
                                <option value="">-- Select Author --</option>
                            </select>
                            <span asp-validation-for="AuthorID" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ReleaseYear" class="form-label fw-bold">
                                    <i class="fas fa-calendar-alt text-primary"></i> Release Year
                                </label>
                                <input asp-for="ReleaseYear" class="form-control" type="number" placeholder="e.g. 2024" />
                                <span asp-validation-for="ReleaseYear" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold">
                                    <i class="fas fa-dollar-sign text-primary"></i> Price
                                </label>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="e.g. 12.99" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageUrl" class="form-label fw-bold">
                                <i class="fas fa-image text-primary"></i> Image URL
                            </label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4" style="background: linear-gradient(135deg, #6366f1, #8b5cf6); border: none; border-radius: 25px;">
                                <i class="fas fa-save"></i> Save Book
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4" style="border-radius: 25px;">
                                <i class="fas fa-arrow-left"></i> Back to Library
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

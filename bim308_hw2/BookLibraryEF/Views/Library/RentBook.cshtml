@{
    ViewData["Title"] = "Rent a Book";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0" style="border-radius: 16px;">
                <div class="card-header text-white text-center" style="background: linear-gradient(135deg, #f59e0b, #d97706); border-radius: 16px 16px 0 0;">
                    <h3 class="mb-0"><i class="fas fa-hand-holding"></i> Rent a Book</h3>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-info alert-dismissible fade show" role="alert">
                            <i class="fas fa-info-circle"></i> @ViewBag.Message
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="RentBook" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="userId" class="form-label fw-bold">
                                <i class="fas fa-user text-warning"></i> Select User
                            </label>
                            <select name="userId" id="userId" class="form-select">
                                <option value="">-- Select User --</option>
                                @if (ViewBag.Users != null)
                                {
                                    @foreach (var item in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Users)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label for="bookId" class="form-label fw-bold">
                                <i class="fas fa-book text-warning"></i> Select Book
                            </label>
                            <select name="bookId" id="bookId" class="form-select">
                                <option value="">-- Select Book --</option>
                                @if (ViewBag.Books != null)
                                {
                                    @foreach (var item in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Books)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn px-4 text-white" style="background: linear-gradient(135deg, #f59e0b, #d97706); border: none; border-radius: 25px;">
                                <i class="fas fa-check"></i> Rent Book
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4" style="border-radius: 25px;">
                                <i class="fas fa-arrow-left"></i> Back to Library
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@model BookLibraryEF.Models.User

@{
    ViewData["Title"] = "Add User";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0" style="border-radius: 16px;">
                <div class="card-header text-white text-center" style="background: linear-gradient(135deg, #10b981, #059669); border-radius: 16px 16px 0 0;">
                    <h3 class="mb-0"><i class="fas fa-user-plus"></i> Add New User</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="AddUser" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">
                                <i class="fas fa-user text-success"></i> Name
                            </label>
                            <input asp-for="Name" class="form-control" placeholder="Enter full name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold">
                                <i class="fas fa-envelope text-success"></i> Email
                            </label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="user@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4" style="background: linear-gradient(135deg, #10b981, #059669); border: none; border-radius: 25px;">
                                <i class="fas fa-save"></i> Save User
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4" style="border-radius: 25px;">
                                <i class="fas fa-arrow-left"></i> Back to Library
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
